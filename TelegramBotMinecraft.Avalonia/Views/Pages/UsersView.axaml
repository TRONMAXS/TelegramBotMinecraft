<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TelegramBotMinecraft.Avalonia.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1220" d:DesignHeight="730"
             x:Class="TelegramBotMinecraft.Avalonia.UsersView"
             x:DataType="vm:UsersViewModel">

    <Grid ColumnDefinitions="*, Auto, 275">

        <GroupBox Grid.Column="0" Header="Разрешения пользователей" Margin="3" FontSize="15" FontFamily="Default" Padding="0">
            <Grid RowDefinitions="*, Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,*">

                    <GroupBox Grid.Column="0" Header="Сервера" Margin="3,0,10,0" FontSize="15" FontFamily="Default" Padding="0">
                        <Grid RowDefinitions="*, Auto" Margin="0">
                            <DataGrid x:Name="ServersGrid" Grid.Row="0" FontSize="12" Margin="0" 
                                      ItemsSource="{Binding Servers}" AutoGenerateColumns="False"
                                      CanUserResizeColumns="False" SelectionMode="Extended"
                                      HorizontalScrollBarVisibility="Disabled" IsReadOnly="False"
                                      GridLinesVisibility="All" BorderThickness="1" BorderBrush="Gray">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTemplateColumn Header="Выбор" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="False" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <DockPanel Grid.Row="1" HorizontalAlignment="Stretch" LastChildFill="False" Margin="0,10,0,0">
                                <Button Content="Отключить все" DockPanel.Dock="Left"/>
                                <Button Content="Включить все" DockPanel.Dock="Right"/>
                            </DockPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Column="2" Header="Команды" Margin="10,0,3,0" FontSize="15" FontFamily="Default" Padding="0">
                        <Grid RowDefinitions="*, Auto" Margin="0">
                            <DataGrid x:Name="CommandsGrid" Grid.Row="0" FontSize="12" Margin="0"
                                      ItemsSource="{Binding Commands}" AutoGenerateColumns="False"
                                      CanUserResizeColumns="False" SelectionMode="Extended"
                                      HorizontalScrollBarVisibility="Disabled" IsReadOnly="False"
                                      GridLinesVisibility="All" BorderThickness="1" BorderBrush="Gray">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название" Binding="{Binding CommandText}" Width="*"/>
                                    <DataGridTemplateColumn Header="Выбор" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="False" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <DockPanel Grid.Row="1" HorizontalAlignment="Stretch" LastChildFill="False" Margin="0,10,0,0">
                                <Button Content="Отключить все" DockPanel.Dock="Left"/>
                                <Button Content="Включить все" DockPanel.Dock="Right"/>
                            </DockPanel>
                        </Grid>
                    </GroupBox>

                </Grid>
                <Button Grid.Row="1" Content="Сохранить" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,15,0,0"/>
            </Grid>

        </GroupBox>

        <Grid Grid.Column="2">
            <GroupBox Header="Пользователи" Margin="3,3,3,3" FontSize="15" FontFamily="Default" Padding="0" HorizontalAlignment="Stretch" >
                <Grid RowDefinitions="*, Auto, Auto">
                    <DataGrid x:Name="UsersGrid"
                              Grid.Row="0"
                              Width=" 250"
                              Margin="0,0,0,10"
                              ItemsSource="{Binding Users}"
                              AutoGenerateColumns="False"
                              CanUserResizeColumns="False"
                              SelectionMode="Extended"
                              HorizontalScrollBarVisibility="Disabled"
                              IsReadOnly="True"
                              GridLinesVisibility="All"
                              BorderThickness="1"
                              BorderBrush="Gray">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0" Spacing="5" Width="250">
                        <Button FontSize="12" Content="Изменить"/>
                        <Button FontSize="12" Content="Сохранить"/>
                        <Button FontSize="12" Content="Удалить"/>
                    </StackPanel>

                    <GroupBox Grid.Row="2" Header="Новый пользователь" Margin="3,5,3,0" FontSize="15" FontFamily="Default" Width="250" Padding="0">
                        <StackPanel Spacing="5">
                            <TextBox IsReadOnly="False" PlaceholderText="Имя" HorizontalAlignment="Stretch"/>
                            <TextBox IsReadOnly="False" PlaceholderText="Id" HorizontalAlignment="Stretch"/>

                            <Button Content="Добавить" Margin="0,5,0,0"/>

                        </StackPanel>
                    </GroupBox>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
