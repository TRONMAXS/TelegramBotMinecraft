<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TelegramBotMinecraft.Avalonia.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1220" d:DesignHeight="730"
             x:Class="TelegramBotMinecraft.Avalonia.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <Grid ColumnDefinitions="*, Auto, *">

        <GroupBox Grid.Column="0" Header="Telegram" Margin="3" FontSize="15" FontFamily="Default" Padding="0">
            <Grid RowDefinitions="*, auto">
                <StackPanel Grid.Row="0" Spacing="10">


                    <GroupBox Header="Настройки бота"  FontSize="15" FontFamily="Default" Padding="0">
                        <StackPanel Spacing="8">
                            <DockPanel LastChildFill="True">
                                <TextBlock Width="150" VerticalAlignment="Center" Text="BotToken:"/>
                                <TextBox Text="{Binding TextBotToken}" PlaceholderText="123456789:ABCdefGHljklMNOpqrSTUvwxYZ" Padding="5,4" PasswordChar="*" RevealPassword="False" Classes="revealPasswordButton"/>
                            </DockPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding CheckAutoBot}" VerticalAlignment="Center"/>
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="Автозапуск бота"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding CheckAutoReconnect}" VerticalAlignment="Center"/>
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="Авторестарт бота"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Прокси" FontSize="15" FontFamily="Default" Padding="0">
                        <StackPanel Spacing="8">
                            <DockPanel LastChildFill="True">
                                <TextBlock Width="150" VerticalAlignment="Center" Text="Хост / IP:"/>
                                <TextBox Text="{Binding TextProxyHost}" PlaceholderText="127.0.0.1" Padding="5,4"/>
                            </DockPanel>
                            <DockPanel LastChildFill="True">
                                <TextBlock Width="150" VerticalAlignment="Center" Text="Port:"/>
                                <TextBox Text="{Binding TextProxyPort}" PlaceholderText="1080" Padding="5,4"/>
                            </DockPanel>
                            <DockPanel LastChildFill="True">
                                <TextBlock Width="150" VerticalAlignment="Center" Text="Admin:"/>
                                <TextBox Text="{Binding TextProxyUsername}" PlaceholderText="Admin" Padding="5,4" PasswordChar="*" RevealPassword="False" Classes="revealPasswordButton"/>
                            </DockPanel>
                            <DockPanel LastChildFill="True">
                                <TextBlock Width="150" VerticalAlignment="Center" Text="Пароль:"/>
                                <TextBox Text="{Binding TextProxyPassword}" PlaceholderText="12345" Padding="5,4" PasswordChar="*" RevealPassword="False" Classes="revealPasswordButton"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
                <Button Grid.Row="1" Content="Coxpaнить и переподключить" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,0"/>
                <Button Grid.Row="1" Content="Вкл бот" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,0"/>
            </Grid>

        </GroupBox>

        <Grid Grid.Column="2">
            <Grid RowDefinitions="auto, *">


                <GroupBox Grid.Row="0" Header="Основные" Margin="3" FontSize="15" FontFamily="Default" Padding="0">
                    <Grid RowDefinitions="*, auto">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding CheckTrayOnStart}" VerticalAlignment="Center"/>
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="В трей при запуске"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding CheckRunAtStartup}" VerticalAlignment="Center"/>
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="Запуск с Windows"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding CheckNotifications}" VerticalAlignment="Center"/>
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="Всплывающие уведомления"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding }" VerticalAlignment="Center"/>
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="Автоматический выбор Java"/>
                            </StackPanel>
                            <Grid>
                                <Button Content="Управление Java" HorizontalAlignment="Left" Margin="0,0,0,0"/>
                                <Button Content="Сохранить" HorizontalAlignment="Center" Margin="10,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="Консоль бота" Margin="3" FontSize="15" FontFamily="Default" Padding="0">
                    <TextBox Grid.Row="0" HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"
                             VerticalContentAlignment="Top"
                             Margin="0"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             IsReadOnly="True"/>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
